{
  "name": "@taiko/cli",
  "version": "0.1.0",
  "description": "Taiko-specific CLI for network management, node operations, bridge interactions, and contract verification",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "taiko": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules ../node_modules/.bin/vitest run"
  },
  "dependencies": {
    "@taikoxyz/taiko-api-client": "*",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
