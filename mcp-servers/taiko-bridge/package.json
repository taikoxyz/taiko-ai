{
  "name": "@taikoxyz/mcp-bridge",
  "version": "0.1.0",
  "description": "MCP server for Taiko L1↔L2 bridge operations and relay monitoring",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "taiko-bridge": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.5.0",
    "@taikoxyz/taiko-api-client": "*",
    "viem": "^2.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
